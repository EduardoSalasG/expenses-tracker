# BACKEND CONF
NODE_ENV=development
PORT=3000
# DB
DATABASE_URL=postgres://expenses:expenses@localhost:6433/expenses_tracker
# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=30
# TELEGRAM
TELEGRAM_BOT_TOKEN=telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org
TELEGRAM_WEBHOOK_SECRET_TOKEN=telegram-webhook-secret-token
# RESEND EMAIL
RESEND_API_KEY=re_your_resend_api_key
RESEND_API_BASE_URL=https://api.resend.com
RESEND_FROM_EMAIL=Expenses Tracker <onboarding@resend.dev>
# MESSAGE INTERPRETER LLM
MESSAGE_INTERPRETER_PROVIDER=github-models
MESSAGE_INTERPRETER_API_KEY=github-token-with-models-access
MESSAGE_INTERPRETER_BASE_URL=https://models.github.ai/inference
MESSAGE_INTERPRETER_MODEL=deepseek/DeepSeek-V3-0324
MESSAGE_INTERPRETER_TEMPERATURE=0.1
# OTP DEBUG
OTP_DEBUG_RESPONSE_ENABLED=false
# Comma-separated list of allowed CORS origins (used by Express CORS).
# For local + public testing you can add multiple origins, e.g.:
# FRONTEND_ORIGIN=http://localhost:4200,https://6nj2hj1k-4200.brs.devtunnels.ms,https://expenses-tracker-easg.netlify.app
# Telegram login links use the last public URL from this list.
# Set to "*" to allow any origin (dev only).
FRONTEND_ORIGIN=http://localhost:4200
USE_IN_MEMORY_REPOSITORIES=false
LEGACY_BUDGETS_ENDPOINTS_ENABLED=true
