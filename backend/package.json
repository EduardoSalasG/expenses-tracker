{
  "name": "@expenses-tracker/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "db:bootstrap": "tsx src/infrastructure/db-runner.ts bootstrap",
    "db:migrate": "tsx src/infrastructure/db-runner.ts migrate",
    "db:migrate:messaging-rename": "tsx src/infrastructure/db-runner.ts migrate:file database/migrations/008_rename_whatsapp_messaging_tables.sql",
    "db:seed": "tsx src/infrastructure/db-runner.ts seed",
    "db:export:data": "tsx src/infrastructure/db-export-data.ts",
    "db:import:data": "tsx src/infrastructure/db-import-data.ts",
    "db:register-test-user": "tsx src/infrastructure/register-test-user.ts",
    "reports:send-due": "tsx src/infrastructure/send-due-reports.ts",
    "interpreter:smoke": "tsx src/infrastructure/message-interpreter-smoke.ts",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.7",
    "eslint": "^9.17.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "5.7.2",
    "vitest": "^2.1.8"
  }
}
