{
  "name": "expenses-tracker",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:db": "docker compose up -d database",
    "dev:backend": "pnpm --filter @expenses-tracker/backend dev",
    "dev:frontend": "pnpm --filter @expenses-tracker/frontend start",
    "dev:stop-app-containers": "docker compose stop backend frontend",
    "db:bootstrap": "pnpm --filter @expenses-tracker/backend db:bootstrap",
    "db:migrate": "pnpm --filter @expenses-tracker/backend db:migrate",
    "db:migrate:messaging": "pnpm --filter @expenses-tracker/backend db:migrate:messaging",
    "db:seed": "pnpm --filter @expenses-tracker/backend db:seed",
    "db:export:data": "pnpm --filter @expenses-tracker/backend db:export:data",
    "db:import:data": "pnpm --filter @expenses-tracker/backend db:import:data",
    "reports:docker:daily": "docker compose run --rm -e REPORT_FREQUENCY=daily report-worker",
    "reports:docker:weekly": "docker compose run --rm -e REPORT_FREQUENCY=weekly report-worker",
    "reports:docker:monthly": "docker compose run --rm -e REPORT_FREQUENCY=monthly report-worker",
    "reports:docker:yearly": "docker compose run --rm -e REPORT_FREQUENCY=yearly report-worker",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@scarf/scarf",
      "esbuild",
      "lmdb",
      "msgpackr-extract"
    ]
  }
}
